{
  "name": "conduit",
  "private": true,
  "version": "0.15.0",
  "description": "AI-powered remote connection manager with MCP server support",
  "author": {
    "name": "Advenimus",
    "email": "support@advenimus.com"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "cross-env CONDUIT_ENV=preview tsc -p electron/tsconfig.json && cd mcp && npx tsc && cd .. && concurrently -k \"cross-env CONDUIT_ENV=preview vite\" \"wait-on http://localhost:1420 && cross-env CONDUIT_ENV=preview electron .\"",
    "dev:electron:prod": "cross-env CONDUIT_ENV=production tsc -p electron/tsconfig.json && cd mcp && npx tsc && cd .. && concurrently -k \"cross-env CONDUIT_ENV=production vite\" \"wait-on http://localhost:1420 && cross-env CONDUIT_ENV=production electron .\"",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json && cd mcp && npx tsc",
    "build:mac": "cross-env CONDUIT_ENV=production npm run build && electron-builder --mac",
    "build:win": "cross-env CONDUIT_ENV=production npm run build && electron-builder --win",
    "build:linux": "cross-env CONDUIT_ENV=production npm run build && electron-builder --linux",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint src",
    "postinstall": "patch-package && node -e \"require('fs').rmSync('node_modules/.vite',{recursive:true,force:true})\" && npx @electron/rebuild --only better-sqlite3,node-pty,koffi,sharp",
    "supabase:start": "cd ../conduit && supabase start",
    "supabase:stop": "cd ../conduit && supabase stop",
    "supabase:restart": "cd ../conduit && supabase stop && supabase start",
    "supabase:status": "cd ../conduit && supabase status"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.45",
    "@fluentui/react-icons": "^2.0.321",
    "@novnc/novnc": "^1.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.95.3",
    "@tabler/icons-react": "^3.36.1",
    "@tailwindcss/typography": "^0.5.19",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.7.1",
    "electron-updater": "^6.7.3",
    "eventsource-parser": "^3.0.6",
    "fast-xml-parser": "^5.3.5",
    "fix-path": "^5.0.0",
    "jsqr": "^1.4.0",
    "koffi": "^2.15.2",
    "node-pty": "^1.1.0",
    "otpauth": "^9.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.2",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "ssh2": "^1.17.0",
    "unist-util-visit": "^5.1.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "jsdom": "^28.0.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.38",
    "rcedit": "^4.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.5"
  },
  "overrides": {
    "nan": "2.26.2"
  }
}
